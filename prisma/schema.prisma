    // schema.prisma


    // ************ important **********
    // After defining your schema, you need to:
    // Generate the Prisma Client: This command reads your schema.prisma and generates the type-safe client code.
    // run this sentence in terminal : npx prisma generate



    generator client {
      provider = "prisma-client-js"
    }

    datasource db {
      provider = "postgresql" // or mysql, sqlserver, sqlite, mongodb
      url      = env("DATABASE_URL")
    }

    model Settings {
      id           Int      @id @default(autoincrement())
      templateName String   @unique
      createTime   DateTime @default(now())
      active       Boolean  @default(false)
    }



    model User {
      id         Int      @id @default(autoincrement())
      username   String   @unique
      email      String   @unique
      created_at DateTime @default(now())
      active  Boolean  @default(true)

      // Relations can also be defined here
      posts      Post[]
    }


    model Post {
      id                   Int      @id @default(autoincrement())
      title                String
      content              String
      published            Boolean  @default(false)
      created_at           DateTime @default(now())
      short_description    String
      image_url            String
    
      // رابطه: هر پست متعلق به یک کاربر است
      author     User     @relation(fields: [authorId], references: [id]) // به مدل User اشاره می‌کند
      authorId   Int      // کلید خارجی که به id در مدل User اشاره دارد
    
    }


    model Product {
      id                           Int         @id @default(autoincrement())
      name                         String
      title                        String
      short_description            String
      description                  String
      main_img_url                 String
      marketing_img_url            String
      mobile_marketing_img_url     String
      price                        Int
      product_url                  String
      create_time                  DateTime    @default(now())
      origin                       String
      url_address                  String

      // Relation type with ProductCategories
      Category        ProductCategories[]

      // Relation type woth Productcolors
      Colors          Productcolors[]

    }

    model Lists {
      id            Int       @id  @default(autoincrement())
      list_type     String

      category      Category[]
      pages         Pages[]
    }

    model Pages {
      id            Int       @id @default(autoincrement())
      name          String
      title         String
      description   String
      url_address   String
      keys          String
      list_type     Int

      list          Lists     @relation(fields: [list_type], references: [id])
    }

    model Category {
      id      Int        @id  @default(autoincrement())
      name             String 
      description      String
      parent_id        Int? 
      list_type        Int
      image_url        String

      list       Lists     @relation(fields: [list_type], references: [id])


      // Recursive relationship for nested Category
      parent     Category?        @relation("CategoryHierarchy", fields: [parent_id], references: [id])
      children   Category[]       @relation("CategoryHierarchy")

      // Relationship with Intermediate Table (ProductCategories)
      products   ProductCategories[]
    }

    model ProductCategories {
      id               Int   @id  @default(autoincrement())
      
      product          Product     @relation(fields: [product_id], references: [id])
      product_id       Int

      category         Category   @relation(fields: [category_id], references:[id]) 
      category_id      Int     

      // Preventing duplication (each product in a category should only appear once)
      @@unique([product_id, category_id])
    }

    model General {
      id                    Int  @id  @default(autoincrement())

      title                 String
      desciption            String
      short_description     String 
      keys                  String
      logo_url              String
      address               String
      tel                   String
      mobile                String
      email                 String
      header_text           String
    }

    model Colors {
      id                    Int  @id   @default(autoincrement())
      name                  String
      
      // Relationship with Intermediate Table (Productcolors)
      products   Productcolors[]
      
      // Relationship with Intermediate Table (Productimages)
      images     Productimages[]

    }


    model Productcolors {
      id                    Int   @id  @default(autoincrement())
      color_id              Int
      product_id            Int

      product          Product     @relation(fields: [product_id], references: [id])
      color            Colors      @relation(fields: [color_id],  references:[id])

      // Preventing duplication (each product in a color pallet should only appear once)
      @@unique([product_id, color_id])
    }

    model Images {
      id                    Int  @id @default(autoincrement())
      image_url             String

      // Relationship with Colors Table
      color          Colors     @relation(fields: [color_id], references:[id])

      // Relationship with Intermediate Table (Productimages)
      colors         Productimages[]
    }

    model Productimages {
      id                    @Int  @id  @default(autoincrement())
      
      product_id            Int
      image_id              Int

      product         Product    @relation(fields: [product_id], references:[id])
      image           Images     @relation(fields: [image_id], references:[id])
    }